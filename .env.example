# Copy to `.env` or `.env.local` (gitignored) and adjust.

# Dev: Vite forwards browser requests from /api/* to this URL (FastAPI, etc.).
# Seeing http://localhost:5177/api/... in DevTools is expected — the proxy sends them here.
# ETIMEDOUT / ECONNREFUSED usually means nothing is listening at this address from your machine.
# Default in vite.config.mjs is http://localhost:8000 — only set this if you need something else.
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# API in Docker on Mac/Windows (reach host from container network — use when Vite runs on host):
# VITE_API_PROXY_TARGET=http://host.docker.internal:8000
